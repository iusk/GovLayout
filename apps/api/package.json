{
  "name": "@usgov/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "sync:congress": "tsx src/sync/cli/congress.ts",
    "sync:fec": "tsx src/sync/cli/fec.ts",
    "sync:opensecrets": "tsx src/sync/cli/fec.ts",
    "sync:judicial": "tsx src/sync/cli/judicial.ts",
    "sync:executive": "tsx src/sync/cli/executive.ts",
    "sync:all": "tsx src/sync/cli/all.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@usgov/shared": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
