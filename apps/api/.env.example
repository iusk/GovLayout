# Server
PORT=4000

# Database (Prisma + SQLite). Path is relative to apps/api/prisma/ (the schema
# dir), so this resolves to apps/api/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# Data-source API keys (Stage 3). Both are FREE and issued instantly by email.
# A single api.data.gov key works for BOTH services, but they're kept separate
# so you can rotate them independently. Only the `sync:*` scripts need these —
# the API server boots and serves cached DB data without them.
# ---------------------------------------------------------------------------

# Congress.gov — member roster, party, state, district, photos.
# Get one at: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# OpenFEC — campaign-finance totals used to compute each member's PAC %.
# (Replaces the retired OpenSecrets API; we still link out to opensecrets.org.)
# Get one at: https://api.open.fec.gov/developers/
# Leave blank to fall back to DEMO_KEY (~30 req/hr — only for a tiny spot-check).
FEC_API_KEY=

# Optional overrides:
# CONGRESS_NUMBER=119      # which Congress to sync (default 119, the 2025–27 session)
# FEC_THROTTLE_MS=1100     # delay between FEC requests to respect the 1,000/hr cap
